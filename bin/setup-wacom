#!/usr/bin/bash

set -euo pipefail

DEVICE_NAME="Wacom Intuos S 2 Pen"
DEFAULT_OUTPUT="DP-1"

output="${1:-$DEFAULT_OUTPUT}"

base_path="/org/kde/KWin/InputDevice"

# List event nodes via DBus introspection
nodes=$(qdbus6 org.kde.KWin "$base_path" org.freedesktop.DBus.Introspectable.Introspect 2>/dev/null \
    | grep -oP 'node name="\Kevent[^"]+')

event_node=""
for node in $nodes; do
    name=$(qdbus6 org.kde.KWin "$base_path/$node" \
        org.freedesktop.DBus.Properties.Get "org.kde.KWin.InputDevice" name 2>/dev/null || true)
    if [[ "$name" == "$DEVICE_NAME" ]]; then
        event_node="$node"
        break
    fi
done

if [[ -z "$event_node" ]]; then
    echo "Error: '$DEVICE_NAME' not found" >&2
    exit 1
fi

dbus_path="$base_path/$event_node"

echo "Device: $DEVICE_NAME ($event_node)"
echo "Mapping to: $output"

qdbus6 org.kde.KWin "$dbus_path" \
    org.freedesktop.DBus.Properties.Set \
    "org.kde.KWin.InputDevice" outputName "$output"

echo "Done"
